{
  "permissions": {
    "allow": ["Bash(npm install *)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; npx biome format --write --fix \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting with Biome..."
          }
        ]
      }
    ]
  }
}
